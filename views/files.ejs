<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Uploaded Log Files</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
  <div class="container py-4">
    <h1 class="mb-4">Uploaded Files</h1>

    <% if (!files || files.length === 0) { %>
      <div class="alert alert-info">No files found in the bucket.</div>
    <% } else { %>
      <div class="list-group">
        <% files.forEach(f => { %>
          <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="/analyze?file=<%= encodeURIComponent(f) %>">
            <span><%= f %></span>
            <span class="badge bg-primary">Analyze</span>
          </a>
        <% }) %>
      </div>
    <% } %>

    <div class="mt-3">
      <a class="btn btn-outline-secondary" href="/">Back</a>
    </div>
  </div>
</body>
</html>