<%- include('partials/head', { title: 'Files - Logalyze' }) %>
  <h1 class="mb-4">Uploaded Files</h1>

  <% if (!files || files.length === 0) { %>
    <div class="alert alert-info">No files found in the bucket.</div>
  <% } else { %>
    <div class="card p-3 mb-3">
      <input id="filter" class="form-control" placeholder="Filter files..." />
    </div>
    <div id="count" class="text-muted mb-2"><%= files.length %> files</div>
    <div id="file-list" class="list-group">
      <% files.forEach(f => { %>
        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center file-item" href="/analyze?file=<%= encodeURIComponent(f) %>">
          <span class="name"><%= f %></span>
          <span class="d-flex gap-2 align-items-center">
            <button class="btn btn-sm btn-outline-secondary copy" data-name="<%= f %>" type="button">Copy name</button>
            <span class="badge bg-primary">Analyze</span>
          </span>
        </a>
      <% }) %>
    </div>
  <% } %>

  <div class="mt-3">
    <a class="btn btn-outline-secondary" href="/">Back</a>
  </div>

  <script>
    const filter = document.getElementById('filter');
    const list = document.getElementById('file-list');
    const items = Array.from(document.querySelectorAll('.file-item'));
    const count = document.getElementById('count');
    filter?.addEventListener('input', () => {
      const q = filter.value.toLowerCase();
      let visible = 0;
      items.forEach(it => {
        const name = it.querySelector('.name').textContent.toLowerCase();
        const show = name.includes(q);
        it.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      count.textContent = `${visible} files`;
    });

    list?.addEventListener('click', async (e) => {
      const btn = e.target.closest('.copy');
      if (!btn) return;
      const name = btn.getAttribute('data-name');
      try {
        await navigator.clipboard.writeText(name);
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy name', 800);
      } catch {}
    });
  </script>
<%- include('partials/footer') %>