<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Log Analytics</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-light">
  <div class="container py-4">
    <h2 class="mb-4">Log Analytics Dashboard</h2>

    <div class="row mb-4">
      <div class="col"><b>Total Requests:</b> <%= total %></div>
      <div class="col"><b>Errors (4xx/5xx):</b> <%= errors %></div>
      <div class="col"><b>Top IP:</b> <%= topIP %></div>
      <div class="col"><b>Top URL:</b> <%= topURL %></div>
    </div>

    <div class="card p-3 mb-4">
      <h5>Status Code Breakdown</h5>
      <canvas id="statusChart" height="150"></canvas>
    </div>

    <div class="card p-3 mb-4">
      <h5>Ask AI About This Log</h5>
      <form id="chat-form">
        <input type="text" class="form-control mb-2" id="user-query" placeholder="e.g. What is the most common error?" required>
        <button class="btn btn-primary" type="submit">Ask</button>
        <div id="ai-response" class="mt-3 text-secondary"></div>
      </form>
    </div>

    <div class="card p-3">
      <h5>Raw Log Content</h5>
      <pre style="max-height: 320px; overflow: auto; white-space: pre-wrap;"><%= logText %></pre>
    </div>
  </div>

  <script>
    const ctx = document.getElementById('statusChart').getContext('2d');
    new Chart(ctx, {
      type: 'pie',
      data: {
        labels: <%- JSON.stringify(statusLabels) %>,
        datasets: [{
          data: <%- JSON.stringify(statusCounts) %>,
          backgroundColor: ['#198754', '#0d6efd', '#ffc107', '#dc3545', '#6c757d', '#6610f2', '#20c997']
        }]
      }
    });

    document.getElementById('chat-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const query = document.getElementById('user-query').value.trim();
      if (!query) return;
      const res = await fetch('/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ logId: <%- JSON.stringify(logId) %>, query })
      });
      const data = await res.json();
      document.getElementById('ai-response').textContent = data.answer;
    });
  </script>
</body>
</html>