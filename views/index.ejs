<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Logalyze</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
  <div class="container py-4">
    <h1 class="mb-4">Logalyze</h1>

    <div class="card p-3 mb-4">
      <h5>Upload a Log File</h5>
      <form action="/upload" method="POST" enctype="multipart/form-data">
        <div class="row g-2 align-items-center">
          <div class="col-md-8">
            <input class="form-control" type="file" name="logfile" accept=".log,text/plain" required />
          </div>
          <div class="col-md-4">
            <button class="btn btn-primary w-100" type="submit">Upload & Analyze</button>
          </div>
        </div>
      </form>
    </div>

    <a class="btn btn-outline-secondary" href="/files">View Uploaded Files</a>
  </div>
</body>
</html>